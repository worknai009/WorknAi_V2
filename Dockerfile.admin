# Build stage
FROM node:18-alpine AS builder

WORKDIR /app

COPY Admin/package*.json ./
RUN npm install

COPY Admin/ .

ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]