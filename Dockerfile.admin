# Build stage
FROM node:18-alpine AS builder

WORKDIR /app

COPY manager/package*.json ./

RUN npm install

COPY manager/ .

ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build

# Production stage
FROM node:18-alpine

WORKDIR /app

RUN npm install -g serve

COPY --from=builder /app/dist ./dist

EXPOSE 3002

CMD ["serve", "-s", "dist", "-l", "3002"]